flowchart TB
    subgraph api [API Layer]
        Router[router.py]
        Schemas[schemas.py]
        Deps[dependencies.py]
    end

    subgraph core [Domain / Application]
        Orch[VideoJobOrchestrator]
        Models[VideoJob / JobStatus / Manifest]
        Ex[exceptions.py]
    end

    subgraph ports [Ports - interfaces]
        IRepo[IJobRepository]
        IEngine[IMediaGenerationEngine]
    end

    subgraph infra [Infrastructure Adapters]
        MemRepo[InMemoryJobRepository]
        Engine[StructuredMediaEngine]
        Renderer[video_renderer.py]
    end

    Client --> Router
    Router --> Orch
    Orch --> IRepo
    Orch --> IEngine
    IRepo --> MemRepo
    IEngine --> Engine
    Engine --> Renderer
    MemRepo --> RAM[(In-memory dict)]
    Renderer --> FS[(storage/artifacts/*.mp4 + *.json)]
