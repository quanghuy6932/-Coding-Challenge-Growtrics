sequenceDiagram
    participant C as Client
    participant API as router.py
    participant O as VideoJobOrchestrator
    participant R as InMemoryJobRepository
    participant E as StructuredMediaEngine
    participant V as video_renderer

    C->>API: POST /api/v1/videos {query}
    API->>O: submit_video_request(query)
    O->>R: save(SUBMITTED)
    API-->>C: 202 + job_id
    API->>O: BackgroundTask start_background_generation(job_id)

    O->>R: get_by_id, save(PROCESSING)
    loop up to MAX_GENERATION_RETRIES
        O->>E: generate_educational_content(query, job_id)
        E->>E: guardrail + knowledge lookup
        E->>V: render_manifest_to_video (executor)
        E->>E: write manifest JSON
    end
    alt success
        O->>R: save(COMPLETED + artifact)
    else failure
        O->>R: save(FAILED + error_message)
    end

    C->>API: GET /videos/{job_id} (poll)
    C->>API: GET /videos/{job_id}/artifact
    API-->>C: MP4 FileResponse
